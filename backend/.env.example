SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enhance_lms
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional compatibility/fallback variables already supported by the project
JWT_SIGNING_KEY=
POSTGRES_ENGINE=django.db.backends.postgresql
POSTGRES_DB=enhance_lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional deployment/security/runtime toggles
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Enable this on Render only while uploaded files are stored on local disk.
# Long term, move uploaded media to object storage.
SERVE_MEDIA_FILES=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
DJANGO_CHANNEL_LAYER_BACKEND=memory
DJANGO_CHANNEL_REDIS_URL=redis://127.0.0.1:6379/0
# Email defaults to the console backend for local development.
EMAIL_PROVIDER=console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=2525
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=no-reply@enhancelms.local
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TIMEOUT=259200

# Example production SMTP provider (Brevo / Sendinblue) for Render:
# EMAIL_PROVIDER=brevo
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-brevo-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
# DEFAULT_FROM_EMAIL=STCFI LMS <stcfilms.noreply@gmail.com>
# FRONTEND_URL=https://lms-production-deploy.vercel.app
# EMAIL_TIMEOUT=15

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@enhancelms.local
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_EAGER_PROPAGATES=True
